# ConnectFlow Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# FARCASTER INTEGRATION
# =============================================================================

# Farcaster Hub URL (default is fine for most use cases)
VITE_FARCASTER_HUB_URL=https://hub.farcaster.xyz

# Neynar API Key (optional but recommended for enhanced features)
# Get your key at: https://neynar.com
VITE_NEYNAR_API_KEY=your_neynar_api_key_here

# =============================================================================
# AI SERVICES
# =============================================================================

# OpenAI API Key (required for AI features)
# Get your key at: https://platform.openai.com
VITE_OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# DATABASE
# =============================================================================

# Supabase Configuration (required)
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =============================================================================
# AUTHENTICATION (Optional)
# =============================================================================

# Privy App ID (optional, for enhanced wallet auth)
# Get from: https://privy.io
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Turnkey API Key (optional, for wallet management)
# Get from: https://turnkey.com
VITE_TURNKEY_API_KEY=your_turnkey_api_key_here

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Set to 'development' for local development
NODE_ENV=development

# Enable/disable mock data fallback (true/false)
VITE_USE_MOCK_DATA=true

# =============================================================================
# PAYMENT SETTINGS
# =============================================================================

# Payment service base URL
VITE_PAYMENT_BASE_URL=https://payments.vistara.dev

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================

# Enable/disable specific features during development
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_MESSAGING=true
VITE_ENABLE_GROUPS=true
VITE_ENABLE_ANALYTICS=false

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# CORS origins (comma-separated for production)
VITE_CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# Rate limiting (requests per minute)
VITE_RATE_LIMIT=60

# =============================================================================
# MONITORING & ANALYTICS (Optional)
# =============================================================================

# Sentry DSN for error tracking
VITE_SENTRY_DSN=your_sentry_dsn_here

# Google Analytics ID
VITE_GA_ID=your_google_analytics_id_here

# =============================================================================
# NOTES
# =============================================================================

# 1. Never commit your actual .env file to version control
# 2. Keep your API keys secure and rotate them regularly
# 3. Use different keys for development and production
# 4. Some features will use fallback/mock data if keys are not provided
# 5. Refer to README.md for detailed setup instructions
